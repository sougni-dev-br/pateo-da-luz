model CatalogImportBatch {
  id               String                @id @default(cuid())
  importFileId     String                @unique
  originalFileName String?
  sheetName        String?
  type             CatalogImportType
  totalRows        Int
  importedRows     Int                   @default(0)
  createdRows      Int                   @default(0)
  updatedRows      Int                   @default(0)
  ignoredRows      Int                   @default(0)
