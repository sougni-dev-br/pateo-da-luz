  sourceType  String    @default("DIRECT")
  rawValue    String?
  createdAt   DateTime  @default(now())

  @@index([dueDate])
  @@index([sourceType])
  @@index([paidDate])
  @@index([paymentMethodId])
  @@index([paidPaymentMethodId])
  @@index([reconciliationStatus])
  @@index([status])
  @@index([payingCompanyId])
  @@index([companyBankAccountId])
}

model PurchaseOrder {
