  @@index([batchId])
  @@index([entityType, entityId])
}

model Purchase {
  id               String             @id @default(cuid())
  purchaseNumber   String?            @unique
  purchaseOrderNumber String?
  duplicateKey     String?
  normalizedInvoiceNumber String?
  normalizedPurchaseOrderNumber String?
  workflowStatus   String             @default("confirmed")
  purchaseDate     DateTime
  competenceMonth  Int
  competenceYear   Int
  supplierId       String
  supplier         Supplier           @relation(fields: [supplierId], references: [id])
  companyId        String?
  company          Company?            @relation(fields: [companyId], references: [id])
  invoiceNumber    String?
  noInvoiceReason  String?
  rawSupplierCode  String?
  paymentMethod    String?
  paymentMethodId  String?
  paymentMethodRef PaymentMethod?      @relation(fields: [paymentMethodId], references: [id])
  creditCardId     String?
  creditCard       CreditCard?         @relation(fields: [creditCardId], references: [id])
  paymentRegime    PaymentRegime      @default(ACCRUAL)
  expenseType      ExpenseType         @default(OTHER)
  expenseTypeId    String?
  expenseTypeRef   ExpenseTypeMaster?  @relation(fields: [expenseTypeId], references: [id])
  smallExpenseTypeId String?
  smallExpenseType   SmallExpenseType? @relation(fields: [smallExpenseTypeId], references: [id])
  isSmallExpense   Boolean            @default(false)
  smallExpenseResponsibleName String?
  smallExpenseAuthorizedBy String?
  smallExpenseMoneyOrigin String?
  smallExpenseNotes String?
  totalAmount      Decimal            @db.Decimal(12, 2)
  sourceFile       String?
  importBatchId    String?
  importBatch      ImportBatch?        @relation(fields: [importBatchId], references: [id])
  status           String              @default("ACTIVE")
  cancelledAt      DateTime?
  cancellationReason String?
  cancelledByUserId String?
  restoredAt       DateTime?
  restoredByUserId String?
  rawRow           Json?
  items            PurchaseItem[]
  cardStatementItems CreditCardStatementItem[]
  installments     PaymentInstallment[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([purchaseDate])
  @@index([purchaseNumber])
  @@index([purchaseOrderNumber])
  @@index([duplicateKey])
  @@index([normalizedInvoiceNumber])
  @@index([normalizedPurchaseOrderNumber])
  @@index([supplierId, status, normalizedInvoiceNumber])
  @@index([supplierId, status, normalizedPurchaseOrderNumber])
  @@index([workflowStatus])
  @@index([competenceYear, competenceMonth])
  @@index([supplierId])
  @@index([companyId])
  @@index([rawSupplierCode])
  @@index([paymentMethodId])
  @@index([creditCardId])
  @@index([expenseTypeId])
  @@index([smallExpenseTypeId])
  @@index([smallExpenseMoneyOrigin])
  @@index([importBatchId])
  @@index([status])
  @@index([cancelledAt])
}

model PurchaseItem {
  id             String   @id @default(cuid())
  purchaseId     String
  purchase       Purchase @relation(fields: [purchaseId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  rawProductCode String?
  rawProductName String
  unit           String?
  unitMeasureId  String?
  unitMeasure    UnitMeasure? @relation(fields: [unitMeasureId], references: [id])
  quantity       Decimal  @db.Decimal(12, 3)
  unitPrice      Decimal  @db.Decimal(12, 4)
  totalPrice     Decimal  @db.Decimal(12, 2)
  convertedUnit  String?
  convertedQuantity Decimal? @db.Decimal(12, 3)
  convertedUnitPrice Decimal? @db.Decimal(12, 4)
  conversionFactorUsed Decimal? @db.Decimal(12, 6)
  conversionMissing Boolean @default(false)
  rawCategory    String?
  rawSubcategory String?
  cardStatementItems CreditCardStatementItem[]
  createdAt      DateTime @default(now())

  @@index([purchaseId])
  @@index([productId])
  @@index([rawProductCode])
  @@index([unitMeasureId])
  @@index([convertedUnit])
  @@index([conversionMissing])
}

model PaymentInstallment {
  id          String    @id @default(cuid())
  purchaseId  String
  purchase    Purchase  @relation(fields: [purchaseId], references: [id])
  dueDate     DateTime?
  paidDate    DateTime?
  paidAmount  Decimal?  @db.Decimal(12, 2)
  amount      Decimal?  @db.Decimal(12, 2)
  installment Int?
  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation("InstallmentPaymentMethod", fields: [paymentMethodId], references: [id])
  paymentMethodName String?
  paidPaymentMethodId String?
  paidPaymentMethod   PaymentMethod? @relation("InstallmentPaidPaymentMethod", fields: [paidPaymentMethodId], references: [id])
  paidPaymentMethodName String?
  paymentNotes String?
  paidByUserId String?
  discountAmount Decimal? @db.Decimal(12, 2)
  surchargeAmount Decimal? @db.Decimal(12, 2)
  differenceReason String?
  reversedAt DateTime?
  reversedByUserId String?
  cashFlowCategory String?
  dreCategory String?
  projectionCategory String?
  cmvCategory String?
  budgetCategory String?
  bankAccount String?
  payingCompanyId       String?
  payingCompany         Company?            @relation("PayingCompany", fields: [payingCompanyId], references: [id])
  companyBankAccountId  String?
