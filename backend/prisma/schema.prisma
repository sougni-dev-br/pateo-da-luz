  @@index([type])
  @@index([createdAt])
}

model CatalogImportChange {
  id           String              @id @default(cuid())
  batchId      String
  batch        CatalogImportBatch  @relation(fields: [batchId], references: [id])
  action       CatalogImportAction
  entityType   CatalogImportType
  entityId     String
