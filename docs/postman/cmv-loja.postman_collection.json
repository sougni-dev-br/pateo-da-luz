{
  "info": {
    "name": "CMV Loja - API Local",
    "description": "Collection basica para validar autenticacao e modulos principais do CMV Loja.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3334"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Saude",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Autenticacao",
      "item": [
        {
          "name": "Login admin local",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pateodaluz.local\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Sessao atual",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Financeiro e compras",
      "item": [
        {
          "name": "Contas a pagar - proximos 15 dias",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/purchases/payables?startDate=2026-06-04&endDate=2026-06-19",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "purchases",
                "payables"
              ],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-06-04"
                },
                {
                  "key": "endDate",
                  "value": "2026-06-19"
                }
              ]
            }
          }
        },
        {
          "name": "Compras - Abril 2026",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/purchases?startDate=2026-04-01&endDate=2026-04-30"
          }
        },
        {
          "name": "Pedidos de compra",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/purchase-orders"
          }
        }
      ]
    },
    {
      "name": "Estoque, inventario e CMV",
      "item": [
        {
          "name": "Inventarios operacionais",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/inventory/operational"
          }
        },
        {
          "name": "Produtos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "CMV Real - periodos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
          "url": "{{baseUrl}}/monthly/cmv-real"
          }
        }
      ]
    },
    {
      "name": "Caixa e relatorios",
      "item": [
        {
          "name": "Dashboard compras Abril 2026",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/dashboard/purchases?year=2026&month=4"
          }
        },
        {
          "name": "Faturas de cartao",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/cards/statements"
          }
        },
        {
          "name": "Auditoria",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/audit"
          }
        }
      ]
    }
  ]
}
